PORT=5000
NODE_ENV=development

# MongoDB (URL-encode special chars in password: @=%40 #=%23 $=%24)
MONGO_URI=mongodb://localhost:27017/mindcare-ai

# JWT - use a strong random string in production
JWT_SECRET=your-secret-key-change-in-production

# AI chat (Groq or OpenAI)
GROQ_API_KEY=your-groq-api-key

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173

# CORS - comma-separated origins in production
# CORS_ORIGINS=https://your-app.vercel.app,https://app.example.com

# SMTP (optional - for password reset emails; if not set, reset link logs to console)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=MindCare AI <noreply@yourdomain.com>
